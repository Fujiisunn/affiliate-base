---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCategory } from '../../categories';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  const slugs = [...new Set(articles.map((a) => a.data.category ?? '記事'))];
  return slugs.map((slug) => ({
    params: { category: slug },
    props: {
      slug,
      articles: articles
        .filter((a) => (a.data.category ?? '記事') === slug)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { slug, articles } = Astro.props;
const cat = getCategory(slug);
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title={`${cat.label}の記事一覧`}
  description={cat.description}
>
  <nav class="breadcrumb" aria-label="パンくず">
    <a href={base}>ホーム</a>
    <span class="breadcrumb__sep">›</span>
    <a href={`${base}category/`}>カテゴリー</a>
    <span class="breadcrumb__sep">›</span>
    <span>{cat.label}</span>
  </nav>

  <div class="layout">
    <div>
      <div class="page-header">
        <h1 class="page-header__title">{cat.label}</h1>
        <span class="page-header__suffix">– category –</span>
      </div>
      <p class="category-intro">{cat.description}</p>

      <div class="article-grid">
        {articles.map((article) => (
          <ArticleCard
            href={`${base}articles/${article.id}/`}
            title={article.data.title}
            description={article.data.description}
            date={article.data.pubDate}
            category={article.data.category}
            thumb={article.data.thumb}
          />
        ))}
      </div>
    </div>

    <Sidebar />
  </div>
</BaseLayout>
