---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import {
  GA4_MEASUREMENT_ID,
  SEND_ON_LOCALHOST,
  CUSTOM_ANALYTICS_SNIPPET,
} from '../analyticsConfig';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  /** OGP画像。相対パス(base起点)または絶対URL。未指定時はデフォルト画像。 */
  image?: string;
  /** ページ種別。記事詳細では 'article' を渡す。 */
  type?: 'website' | 'article';
  /** 記事の公開日(type='article' のとき構造化データに使用)。 */
  publishedDate?: Date;
  /** 記事の更新日。 */
  modifiedDate?: Date;
}

const {
  title,
  description = SITE_DESCRIPTION,
  noindex = false,
  image = 'favicon.svg',
  type = 'website',
  publishedDate,
  modifiedDate,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const fullTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;

// 絶対URLの算出(site 未設定のローカル等では相対のまま)
const site = Astro.site;
const canonicalURL = site ? new URL(Astro.url.pathname, site).href : Astro.url.pathname;
const rssURL = `${base}rss.xml`;

function toAbsolute(path: string): string {
  if (/^https?:\/\//.test(path)) return path;
  const rel = path.startsWith('/') ? path.slice(1) : `${base.replace(/^\//, '')}${path}`;
  return site ? new URL(rel, site).href : `/${rel}`;
}
const ogImage = toAbsolute(image);

// 構造化データ(JSON-LD)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: site ? new URL(base, site).href : base,
};

const articleSchema =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title ?? SITE_TITLE,
        description,
        image: ogImage,
        datePublished: publishedDate?.toISOString(),
        dateModified: (modifiedDate ?? publishedDate)?.toISOString(),
        mainEntityOfPage: canonicalURL,
        publisher: {
          '@type': 'Organization',
          name: SITE_TITLE,
        },
      }
    : null;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={rssURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    {type === 'article' && publishedDate && (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    )}
    {type === 'article' && modifiedDate && (
      <meta property="article:modified_time" content={modifiedDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{fullTitle}</title>

    {/* === Google AdSense を使う場合、ローダーの <script> をこの下に1回だけ貼る === */}
    {/* 例: <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXX" crossorigin="anonymous" is:inline></script> */}

    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}

    {/* === PV計測(Google Analytics 4)。analyticsConfig.ts でID設定 === */}
    {GA4_MEASUREMENT_ID && (
      <Fragment>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}
          is:inline
        ></script>
        <script is:inline define:vars={{ id: GA4_MEASUREMENT_ID, sendOnLocalhost: SEND_ON_LOCALHOST }}>
          (function () {
            var host = location.hostname;
            var isLocal = host === 'localhost' || host === '127.0.0.1' || host === '';
            if (isLocal && !sendOnLocalhost) return;
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', id);
          })();
        </script>
      </Fragment>
    )}
    {/* === その他の計測タグ(任意。analyticsConfig.ts に貼る) === */}
    {CUSTOM_ANALYTICS_SNIPPET && (
      <Fragment set:html={CUSTOM_ANALYTICS_SNIPPET} />
    )}
  </head>
  <body>
    <div class="top-accent"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <a href="#top" class="back-to-top" aria-label="ページトップへ">↑</a>

    {/* adConfig.ts に貼られた広告タグ内の <script> を実行させるための処理 */}
    <script is:inline>
      document.querySelectorAll('.ad-slot__inner script').forEach((oldScript) => {
        const s = document.createElement('script');
        for (const attr of oldScript.attributes) s.setAttribute(attr.name, attr.value);
        s.textContent = oldScript.textContent;
        oldScript.replaceWith(s);
      });
    </script>
  </body>
</html>
