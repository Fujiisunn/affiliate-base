---
import { SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL;

const navItems = [
  { label: 'ホーム', href: base },
  { label: '記事一覧', href: base },
  { label: 'カテゴリー', href: `${base}category/` },
  { label: '運営者情報', href: `${base}about/` },
  { label: 'お問い合わせ', href: `${base}contact/` },
];
---
<header class="site-header" id="top">
  <div class="site-header__inner">
    <a href={base} class="site-header__logo" aria-label={SITE_TITLE}>
      <span class="site-header__logo-title">{SITE_TITLE}</span>
    </a>
    <nav class="site-header__nav">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>
